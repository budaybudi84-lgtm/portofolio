    <script>
        // Data Omset Penjualan Online PT Dexatama
        const revenueData = {
            '2022': {
                year: '2022',
                amount: 'Rp 48.516.150',
                growth: 'Mulai Terbuka',
                desc: 'Peletakan batu pertama sistem penjualan digital PT Dexatama, membangun fondasi awal e-commerce yang tadinya nihil.'
            },
            '2023': {
                year: '2023',
                amount: 'Rp 586.771.607',
                growth: '+1,110%',
                desc: 'Lonjakan eksponensial di tahun kedua pengelolaan berkat integrasi penuh Shopee & Tokopedia dengan dukungan promosi ads serta manajemen katalog produk yang mendalam.'
            },
            '2024': {
                year: '2024',
                amount: 'Rp 241.560.614',
                growth: 'Penyesuaian Pasar',
                desc: 'Periode transisi dan adaptasi strategi baru setelah terjadi pergeseran regulasi e-commerce utama. Berhasil mempertahankan kestabilan transaksi.'
            },
            '2025': {
                year: '2025',
                amount: 'Rp 839.271.678',
                growth: '+247%',
                desc: 'Pencapaian fantastis senilai Rp 839 Juta+ diraih berkat pemeliharaan konten SEO harian, analisis pasar tren terkini, optimasi keyword pencarian e-commerce, dan penawaran instan yang cepat kepada calon pembeli.'
            }
        };

        // Judul Headline Peran (Typewriter Effect)
        const roles = [
            "Digital Marketing Specialist",
            "WordPress & Web Developer",
            "Social Media Manager",
            "E-commerce Growth Hacker"
        ];
        let roleIndex = 0;
        let charIndex = 0;
        let currentText = '';
        let isDeleting = false;
        
        function typeWriter() {
            const typewriterElement = document.getElementById('typewriter-text');
            if (!typewriterElement) return;

            const fullText = roles[roleIndex];
            
            if (isDeleting) {
                currentText = fullText.substring(0, charIndex - 1);
                charIndex--;
            } else {
                currentText = fullText.substring(0, charIndex + 1);
                charIndex++;
            }
            
            typewriterElement.innerHTML = currentText;
            
            let typeSpeed = isDeleting ? 40 : 80;
            
            if (!isDeleting && currentText === fullText) {
                typeSpeed = 1500; // Jeda saat kalimat lengkap diketik
                isDeleting = true;
            } else if (isDeleting && currentText === '') {
                isDeleting = false;
                roleIndex = (roleIndex + 1) % roles.length;
                typeSpeed = 500; // Jeda sebelum mengetik kata baru
            }
            
            setTimeout(typeWriter, typeSpeed);
        }

        // Fungsi Interaksi Grafik Penjualan
        function selectRevenueYear(year) {
            const data = revenueData[year];
            if (!data) return;

            // Perbarui UI Panel Detail
            const container = document.getElementById('revenue-detail-container');
            container.innerHTML = `
                <div>
                    <span class="text-xs text-slate-500 block">Tahun Operasional</span>
                    <h3 class="text-3xl font-extrabold text-white font-mono">${data.year}</h3>
                </div>

                <div class="p-3 bg-slate-950 rounded-xl border border-slate-800">
                    <span class="text-xs text-slate-500 block">Total Omset Penjualan (E-Commerce)</span>
                    <p class="text-2xl font-bold text-teal-400 font-mono mt-1">${data.amount}</p>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div class="p-3 bg-slate-950/60 rounded-xl border border-slate-850">
                        <span class="text-[10px] text-slate-500 block">Laju Pertumbuhan</span>
                        <span class="text-xs font-bold text-white block mt-0.5">${data.growth}</span>
                    </div>
                    <div class="p-3 bg-slate-950/60 rounded-xl border border-slate-850">
                        <span class="text-[10px] text-slate-500 block">Pengelola Toko</span>
                        <span class="text-xs font-bold text-white block mt-0.5">Budi (Admin)</span>
                    </div>
                </div>

                <p class="text-xs text-slate-400 leading-relaxed pt-2">
                    ${data.desc}
                </p>
            `;

            // Atur ulang kelas aktif pada visual bar grafik
            const wrappers = document.querySelectorAll('.revenue-bar-wrapper');
            wrappers.forEach(wrap => {
                const barYear = wrap.getAttribute('data-year');
                const barElement = wrap.querySelector('div:nth-child(2)');
                const textElement = wrap.querySelector('span');
                const tooltip = wrap.querySelector('.revenue-tooltip');

                if (barYear === year) {
                    // Berikan style aktif
                    barElement.className = "w-full max-w-[50px] rounded-t-lg transition-all duration-500 relative bg-gradient-to-t from-teal-600 to-teal-400 shadow-lg shadow-teal-500/20";
                    barElement.innerHTML = '<div class="absolute inset-0 bg-white/10 rounded-t-lg"></div>';
                    textElement.className = "mt-3 text-xs font-bold font-mono text-teal-400";
                    tooltip.className = "revenue-tooltip mb-2 px-2 py-1 rounded text-[11px] font-bold font-mono transition-all duration-200 bg-teal-400 text-slate-950 scale-110 -translate-y-1";
                } else {
                    // Gaya tidak aktif
                    barElement.className = "w-full max-w-[50px] rounded-t-lg transition-all duration-500 relative bg-gradient-to-t from-slate-800 to-slate-700 group-hover:from-slate-700 group-hover:to-teal-500/60";
                    barElement.innerHTML = '';
                    textElement.className = "mt-3 text-xs font-bold font-mono text-slate-400 group-hover:text-white";
                    tooltip.className = "revenue-tooltip mb-2 px-2 py-1 rounded text-[11px] font-bold font-mono transition-all duration-200 opacity-0 group-hover:opacity-100 bg-slate-800 text-slate-300";
                }
            });
        }

        // Fungsi Filter Portofolio
        function filterPortfolio(category) {
            const cards = document.querySelectorAll('.portfolio-card');
            cards.forEach(card => {
                const cardCat = card.getAttribute('data-category');
                if (category === 'all' || cardCat === category) {
                    card.classList.remove('hidden');
                    // Tambahkan efek transisi halus
                    card.style.opacity = '0';
                    setTimeout(() => {
                        card.style.opacity = '1';
                        card.style.transition = 'opacity 300ms ease-in-out';
                    }, 50);
                } else {
                    card.classList.add('hidden');
                }
            });

            // Perbarui tombol filter aktif
            const filterBtns = document.querySelectorAll('.portfolio-filter-btn');
            filterBtns.forEach(btn => {
                btn.className = "portfolio-filter-btn px-4 py-2 rounded-full border transition-all cursor-pointer bg-slate-900 text-slate-400 border-slate-800 hover:text-white";
            });

            const activeBtn = document.getElementById(`btn-filter-${category}`);
            if (activeBtn) {
                activeBtn.className = "portfolio-filter-btn px-4 py-2 rounded-full border transition-all cursor-pointer bg-teal-500 text-white border-teal-500 shadow-md shadow-teal-500/15";
            }
        }

        // Fungsi Salin Alamat Email
        function copyEmailAddress() {
            const btn = document.getElementById('btn-copy-email');
            
            // Clipboard fallback sesuai manual
            const el = document.createElement('textarea');
            el.value = 'budaybudi84@gmail.com';
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            btn.textContent = 'Tersalin!';
            btn.className = "text-[10px] font-mono text-white bg-emerald-500 border border-emerald-400 px-1.5 py-0.5 rounded cursor-pointer transition-all";
            
            setTimeout(() => {
                btn.textContent = 'Salin';
                btn.className = "text-[10px] font-mono text-teal-400 bg-teal-500/10 border border-teal-500/20 px-1.5 py-0.5 rounded cursor-pointer transition-all hover:bg-teal-500/20";
            }, 2000);
        }

        // Pengiriman Formulir Simulasi
        function handleContactSubmit(e) {
            e.preventDefault();
            const name = document.getElementById('form-name').value;
            const email = document.getElementById('form-email').value;
            const message = document.getElementById('form-message').value;

            if (!name || !email || !message) return;

            // Tampilkan UI pesan sukses
            document.getElementById('portfolio-contact-form').classList.add('hidden');
            document.getElementById('contact-success-state').classList.remove('hidden');

            // Kembalikan form ke keadaan awal setelah beberapa detik
            setTimeout(() => {
                document.getElementById('portfolio-contact-form').reset();
                document.getElementById('portfolio-contact-form').classList.remove('hidden');
                document.getElementById('contact-success-state').classList.add('hidden');
            }, 5000);
        }

        // Kontrol Tampilan Modal CV
        function openCvModal() {
            document.getElementById('cv-modal').classList.remove('hidden');
            document.body.style.overflow = 'hidden'; // Kunci scroll halaman utama
        }

        function closeCvModal() {
            document.getElementById('cv-modal').classList.add('hidden');
            document.body.style.overflow = ''; // Aktifkan kembali scroll
        }

        // Jalankan saat DOM Selesai Dimuat
        window.onload = function() {
            // Memulai pengetikan dinamis headline
            typeWriter();
            
            // Inisialisasi ikon Lucide
            lucide.createIcons();
        };
    </script>
</body>
</html>
